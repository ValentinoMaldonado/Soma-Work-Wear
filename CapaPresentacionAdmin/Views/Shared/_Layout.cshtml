<!DOCTYPE html>
<html>
<head>  
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - SomaWorkWear Admin</title>
    @Styles.Render("~/Content/fontawesome")
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")

    <style>
        /* Small custom styles for a modern sidebar */
        .offcanvas.offcanvas-start {
            width: 280px; /* fixed width */
            max-width: 90%;
        }
        .sidebar-brand {
            padding: 1rem 1.25rem;
            font-weight: 700;
            font-size: 1.05rem;
        }
        .sidebar .list-group-item {
            border: none;
            padding: 0.9rem 1.25rem;
            transition: background .15s ease;
        }
        .sidebar .list-group-item:hover {
            background: rgba(0,0,0,0.03);
        }
        .sidebar .list-group-item .fa-fw { width: 1.25rem; }
        .sidebar .user-block { padding: 1rem 1.25rem; }
        .sidebar .user-block .avatar { width:40px;height:40px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;background:#6c757d;color:white }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark">
        <div class="container">
            <div class="d-flex align-items-center">
                @Html.ActionLink("SomaWorkWear", "Index", "Home", new { area = "" }, new { @class = "navbar-brand" })
                <!-- Sidebar toggle button -->
                <button class="btn btn-outline-light ms-2" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebar" aria-controls="sidebar" title="Abrir menú">
                    <i class="fas fa-bars"></i>
                </button>
            </div>
            <button type="button" class="navbar-toggler" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" title="Toggle navigation" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav flex-grow-1">
                    <li class="nav-item">@Html.ActionLink("Inicio", "Index", "Home", new { area = "" }, new { @class = "nav-link" })</li>
                    <li class="nav-item">@Html.ActionLink("Acerca", "About", "Home", new { area = "" }, new { @class = "nav-link" })</li>
                    <li class="nav-item">@Html.ActionLink("Contacto", "Contact", "Home", new { area = "" }, new { @class = "nav-link" })</li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Offcanvas sidebar -->
    @{ 
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
        Func<string, string, string> isActive = (c, a) => (string.Equals(currentController, c, StringComparison.OrdinalIgnoreCase)
                                                          && (string.IsNullOrEmpty(a) || string.Equals(currentAction, a, StringComparison.OrdinalIgnoreCase)))
                                                         ? "active" : "";
    }

    <div class="offcanvas offcanvas-start sidebar" tabindex="-1" id="sidebar" aria-labelledby="sidebarLabel">
      <div class="offcanvas-header bg-primary text-white">
        <div class="sidebar-brand">Panel - Administración</div>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
      </div>
      <div class="offcanvas-body p-0">
        <div class="list-group list-group-flush">
          <a href="@Url.Action("Categoria","Mantenedor")" class="list-group-item list-group-item-action d-flex align-items-center @isActive("Mantenedor","Categoria")">
            <i class="fas fa-tags fa-fw me-2 text-primary"></i>
            <span>Categoría</span>
          </a>
          <a href="@Url.Action("Marca","Mantenedor")" class="list-group-item list-group-item-action d-flex align-items-center @isActive("Mantenedor","Marca")">
            <i class="fas fa-bookmark fa-fw me-2 text-primary"></i>
            <span>Marca</span>
          </a>
          <a href="@Url.Action("Producto","Mantenedor")" class="list-group-item list-group-item-action d-flex align-items-center @isActive("Mantenedor","Producto")">
            <i class="fas fa-box-open fa-fw me-2 text-primary"></i>
            <span>Producto</span>
          </a>
        </div>

        <div class="user-block border-top mt-3">
          <div class="d-flex align-items-center px-3">
            <div class="avatar"> <i class="fas fa-user"></i> </div>
            <div class="ms-2">
              <div class="fw-bold">Nombre Apellido</div>
              <small class="text-muted">Administrador</small>
            </div>
          </div>
          <div class="px-3 mt-3 mb-3">
            <a class="btn btn-outline-danger btn-sm w-100" href="@Url.Action("Logout","Account")">Cerrar sesión</a>
          </div>
        </div>

      </div>
    </div>

    <div class="container body-content">
        @RenderBody()
        <hr />
        <footer>
            <p>&copy; @DateTime.Now.Year - My ASP.NET Application</p>
        </footer>
    </div>

    @Scripts.Render("~/bundles/jquery")
    <!-- load bootstrap bundle and fontawesome directly -->
    <script src="@Url.Content("~/Scripts/bootstrap.bundle.min.js")"></script>
    <script src="@Url.Content("~/Scripts/fontawesome/all.min.js")"></script>
    @RenderSection("scripts", required: false)
</body>
</html>
