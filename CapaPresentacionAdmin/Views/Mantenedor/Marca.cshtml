@{
    ViewBag.Title = "Marcas";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="admin-page" aria-labelledby="brandTitle">
    <div class="admin-page-header">
        <div>
            <span class="admin-eyebrow">Mantenedor</span>
            <h1 id="brandTitle">Marcas</h1>
            <p>Gestiona marcas del catalogo y controla si estan disponibles para productos.</p>
        </div>
        <button id="btnCrear" class="btn btn-glass" type="button" data-bs-toggle="modal" data-bs-target="#modalMarca">
            <i class="fas fa-plus-circle me-1"></i> Nueva marca
        </button>
    </div>

    <div class="futuristic-card">
        <div class="futuristic-header">
            <div>
                <div class="page-title">Listado de marcas</div>
                <small class="text-muted">Datos cargados via AJAX</small>
            </div>
        </div>

        <div class="table-responsive">
            <table id="tabla" class="table table-borderless futuristic-table mb-0" style="width:100%">
                <thead>
                    <tr>
                        <th style="width:10%"></th>
                        <th style="width:10%">ID</th>
                        <th style="width:60%">Descripcion</th>
                        <th style="width:20%">Activo</th>
                    </tr>
                </thead>
                <tbody>
                </tbody>
            </table>
        </div>
    </div>
</section>

<div class="modal fade" id="modalMarca" tabindex="-1" aria-labelledby="modalMarcaLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalMarcaLabel">Marca</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="formMarca">
                    <input type="hidden" id="IdMarca" value="0" />
                    <div class="row g-2">
                        <div class="col-md-8">
                            <label class="form-label">Descripcion</label>
                            <input type="text" class="form-control" id="Descripcion" maxlength="100" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Activo</label>
                            <select id="Activo" class="form-select">
                                <option value="1">Si</option>
                                <option value="0">No</option>
                            </select>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-ghost" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-glass" id="btnGuardar">Guardar</button>
            </div>
        </div>
    </div>
</div>

@section styles {
    @Styles.Render("~/Content/datatables")
}

@section scripts {
    @Scripts.Render("~/bundles/datatables")
    @Scripts.Render("~/bundles/datatables.responsive")

    <script>
        $(document).ready(function () {
            var tabla = $('#tabla').DataTable({
                responsive: true,
                ordering: false,
                ajax: {
                    url: '@Url.Action("ListarMarcas","Mantenedor")',
                    type: 'GET',
                    dataType: 'json'
                },
                columns: [
                    {
                        data: null,
                        render: function () {
                            return '<div class="actions-cell">'
                                + '<button class="btn action-btn btn-edit btn-sm btn-editar" title="Editar"> <i class="fas fa-pen"></i> </button>'
                                + '<button class="btn action-btn btn-delete btn-sm btn-eliminar" title="Eliminar"> <i class="fas fa-trash"></i> </button>'
                                + '</div>';
                        },
                        orderable: false
                    },
                    { data: 'IdMarca' },
                    { data: 'Descripcion' },
                    {
                        data: 'Activo',
                        render: function (data) {
                            if (data === true || data === 1 || data === '1') {
                                return '<span class="badge-yes">Si</span>';
                            }
                            return '<span class="badge-no">No</span>';
                        },
                        className: 'text-center'
                    }
                ],
                language: {
                    emptyTable: 'No hay marcas cargadas',
                    info: 'Mostrando _START_ a _END_ de _TOTAL_ marcas',
                    infoEmpty: 'Mostrando 0 a 0 de 0 marcas',
                    infoFiltered: '(filtrado de _MAX_ marcas totales)',
                    lengthMenu: 'Mostrar _MENU_ marcas',
                    loadingRecords: 'Cargando...',
                    processing: 'Procesando...',
                    search: 'Buscar:',
                    zeroRecords: 'No se encontraron marcas',
                    paginate: {
                        first: 'Primero',
                        last: 'Ultimo',
                        next: 'Siguiente',
                        previous: 'Anterior'
                    }
                }
            });

            $('#btnCrear').on('click', function () {
                $('#modalMarcaLabel').text('Crear marca');
                $('#formMarca')[0].reset();
                $('#IdMarca').val(0);
                $('#Activo').val('1');
            });

            $('#tabla tbody').on('click', '.btn-editar', function () {
                var data = tabla.row($(this).closest('tr')).data();
                if (!data) return;

                $('#modalMarcaLabel').text('Editar marca');
                $('#IdMarca').val(data.IdMarca);
                $('#Descripcion').val(data.Descripcion);
                $('#Activo').val(data.Activo == 1 || data.Activo === true ? '1' : '0');

                var modal = new bootstrap.Modal(document.getElementById('modalMarca'));
                modal.show();
            });

            $('#tabla tbody').on('click', '.btn-eliminar', function () {
                var data = tabla.row($(this).closest('tr')).data();
                if (!data) return;

                if (confirm('Eliminar marca ' + data.Descripcion + '?')) {
                    $.ajax({
                        url: '@Url.Action("EliminarMarca","Mantenedor")',
                        method: 'POST',
                        data: { id: data.IdMarca },
                        success: function (res) {
                            if (res.success) {
                                tabla.ajax.reload(null, false);
                                alert(res.message || 'Marca eliminada');
                            } else {
                                alert(res.message || 'Error al eliminar');
                            }
                        },
                        error: function () { alert('Error del servidor'); }
                    });
                }
            });

            $('#btnGuardar').on('click', function () {
                var marca = {
                    IdMarca: parseInt($('#IdMarca').val() || 0),
                    Descripcion: $('#Descripcion').val(),
                    Activo: $('#Activo').val() == '1'
                };

                $.ajax({
                    url: '@Url.Action("GuardarMarca","Mantenedor")',
                    method: 'POST',
                    data: marca,
                    success: function (res) {
                        if (res.success) {
                            tabla.ajax.reload(null, false);
                            var modalEl = document.getElementById('modalMarca');
                            var modal = bootstrap.Modal.getInstance(modalEl);
                            if (modal) modal.hide();
                            alert(res.message || 'Operacion realizada correctamente');
                        } else {
                            alert(res.message || 'Error al guardar');
                        }
                    },
                    error: function () { alert('Error del servidor'); }
                });
            });
        });
    </script>
}
