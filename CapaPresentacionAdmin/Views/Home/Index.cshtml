@{
    ViewBag.Title = "Panel";
}

<section class="admin-dashboard" aria-labelledby="dashboardTitle">
    <div class="dashboard-hero">
        <div>
            <span class="admin-eyebrow">Operacion interna</span>
            <h1 id="dashboardTitle">Panel de control SomaWorkWear</h1>
            <p>
                Vista general para administrar catalogo, usuarios y recursos comerciales desde una interfaz oscura, clara y enfocada.
            </p>
        </div>
        <a class="btn btn-glass" href="@Url.Action("Producto", "Mantenedor")">
            <i class="fas fa-box-open me-1"></i> Gestionar productos
        </a>
    </div>

    <div class="admin-stat-grid">
        <article class="stat-card">
            <i class="fas fa-tags"></i>
            <span>Categorias</span>
            <strong>Activas</strong>
        </article>
        <article class="stat-card">
            <i class="fas fa-bookmark"></i>
            <span>Marcas</span>
            <strong>Catalogadas</strong>
        </article>
        <article class="stat-card">
            <i class="fas fa-boxes"></i>
            <span>Productos</span>
            <strong>En revision</strong>
        </article>
        <article class="stat-card">
            <i class="fas fa-users"></i>
            <span>Usuarios</span>
            <strong>Administrables</strong>
        </article>
    </div>

    <div class="admin-card-grid">
        <article class="admin-card">
            <span class="admin-eyebrow">Flujo sugerido</span>
            <h2>Actualiza el catalogo por etapas</h2>
            <p>Primero categorias, luego marcas y por ultimo productos. Asi se mantiene la carga ordenada y facil de auditar.</p>
        </article>
        <article class="admin-card">
            <span class="admin-eyebrow">Control visual</span>
            <h2>Interfaz oscura y consistente</h2>
            <p>Los modulos comparten botones transparentes, bordes azul/verde y estados hover para navegar con menos ruido.</p>
        </article>
    </div>
</section>
