<!DOCTYPE html>
<html lang="es" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - SomaWorkWear</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
</head>
<body class="store-shell">
    <nav class="navbar navbar-expand-lg navbar-dark soma-navbar">
        <div class="container">
            @Html.ActionLink("SomaWorkWear", "Index", "Home", new { area = "" }, new { @class = "navbar-brand brand-mark" })
            <button type="button" class="navbar-toggler soma-toggler" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" title="Abrir navegacion" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Abrir navegacion">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
                    <li class="nav-item">@Html.ActionLink("Inicio", "Index", "Home", new { area = "" }, new { @class = "nav-link" })</li>
                    <li class="nav-item">@Html.ActionLink("Nosotros", "About", "Home", new { area = "" }, new { @class = "nav-link" })</li>
                    <li class="nav-item">@Html.ActionLink("Contacto", "Contact", "Home", new { area = "" }, new { @class = "nav-link" })</li>
                    <li class="nav-item">
                        <a class="btn btn-glass btn-sm ms-lg-2" href="@Url.Action("Contact", "Home")">Cotizar</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="body-content">
        @RenderBody()
    </div>

    <footer class="soma-footer">
        <div class="container d-flex flex-column flex-md-row justify-content-between gap-2">
            <span>&copy; @DateTime.Now.Year SomaWorkWear</span>
            <span>Indumentaria laboral, seguridad y equipamiento corporativo.</span>
        </div>
    </footer>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>
</html>
