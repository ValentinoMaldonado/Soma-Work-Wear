@{
    ViewBag.Title = "Inicio";
}

<main class="store-home">
    <section class="store-hero" aria-labelledby="homeTitle">
        <div class="container hero-grid">
            <div class="hero-copy">
                <span class="eyebrow">Nueva linea industrial</span>
                <h1 id="homeTitle">Workwear tecnico para equipos que no paran</h1>
                <p class="lead">
                    Prendas resistentes, comodas y listas para jornadas exigentes. Disenamos soluciones textiles para produccion, logistica, obra y servicios.
                </p>
                <div class="hero-actions">
                    <a class="btn btn-glass btn-lg" href="@Url.Action("Contact", "Home")">Solicitar cotizacion</a>
                    <a class="btn btn-ghost btn-lg" href="@Url.Action("About", "Home")">Conocer la marca</a>
                </div>
            </div>
            <div class="hero-visual" aria-hidden="true">
                <img src="@Url.Content("~/Content/images/workwear-hero.png")" alt="" />
            </div>
        </div>
    </section>

    <section class="container section-band" aria-label="Categorias destacadas">
        <div class="section-heading">
            <span class="eyebrow">Catalogo</span>
            <h2>Equipamiento por rubro</h2>
        </div>
        <div class="feature-grid">
            <article class="feature-card">
                <span class="feature-kicker">01</span>
                <h3>Industria y logistica</h3>
                <p>Camperas, pantalones cargo, chalecos reflectivos y accesorios de alta durabilidad.</p>
            </article>
            <article class="feature-card">
                <span class="feature-kicker">02</span>
                <h3>Servicios tecnicos</h3>
                <p>Uniformes livianos, respirables y listos para movilidad continua durante todo el dia.</p>
            </article>
            <article class="feature-card">
                <span class="feature-kicker">03</span>
                <h3>Imagen corporativa</h3>
                <p>Prendas personalizables para unificar presencia de marca sin perder proteccion.</p>
            </article>
        </div>
    </section>

    <section class="container split-section" aria-label="Ventajas">
        <div>
            <span class="eyebrow">Rendimiento</span>
            <h2>Una estetica sobria con materiales preparados para uso real</h2>
            <p>
                Trabajamos con telas reforzadas, costuras de alta exigencia y terminaciones pensadas para sostener una imagen profesional en ambientes complejos.
            </p>
        </div>
        <div class="metric-grid">
            <div class="metric-tile">
                <strong>24/7</strong>
                <span>Pedidos empresariales</span>
            </div>
            <div class="metric-tile">
                <strong>+35</strong>
                <span>Modelos base</span>
            </div>
            <div class="metric-tile">
                <strong>100%</strong>
                <span>Modo corporativo</span>
            </div>
        </div>
    </section>
</main>
