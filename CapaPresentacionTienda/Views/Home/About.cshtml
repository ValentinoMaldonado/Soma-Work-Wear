@{
    ViewBag.Title = "Nosotros";
}

<main class="container content-page" aria-labelledby="aboutTitle">
    <section class="page-hero compact">
        <span class="eyebrow">SomaWorkWear</span>
        <h1 id="aboutTitle">Indumentaria laboral con presencia tecnica y diseno oscuro</h1>
        <p>
            Somos una marca orientada a empresas que necesitan vestir equipos completos con prendas resistentes, funcionales y coherentes con su identidad visual.
        </p>
    </section>

    <section class="info-grid" aria-label="Informacion institucional">
        <article class="glass-panel">
            <h2>Que hacemos</h2>
            <p>
                Proveemos uniformes, camperas, pantalones, chalecos y accesorios de trabajo para operaciones industriales, logisticas, comerciales y tecnicas.
            </p>
        </article>
        <article class="glass-panel">
            <h2>Como trabajamos</h2>
            <p>
                Relevamos necesidades, definimos talles, proponemos materiales y coordinamos entregas por etapa para que la renovacion de vestuario sea ordenada.
            </p>
        </article>
        <article class="glass-panel">
            <h2>Valores</h2>
            <p>
                Priorizamos durabilidad, comodidad, seguridad visual y una estetica profesional que se mantenga vigente en el uso diario.
            </p>
        </article>
    </section>

    <section class="timeline-strip" aria-label="Proceso de trabajo">
        <div>
            <strong>01</strong>
            <span>Diagnostico</span>
        </div>
        <div>
            <strong>02</strong>
            <span>Seleccion</span>
        </div>
        <div>
            <strong>03</strong>
            <span>Personalizacion</span>
        </div>
        <div>
            <strong>04</strong>
            <span>Entrega</span>
        </div>
    </section>
</main>
